{
  "name": "aipolicy",
  "version": "1.0.0",
  "private": true,
  "description": "Generate AI policy files for your repository",
  "type": "module",
  "scripts": {
    "serve": "python3 -m http.server 8919 -d public",
    "generate": "node scripts/generate-presets.js",
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js && npm run lint:md",
    "lint:html": "htmlhint public/*.html",
    "lint:css": "stylelint 'public/styles/**/*.css'",
    "lint:js": "eslint public/scripts/",
    "lint:md": "markdownlint-cli2 '*.md' 'public/presets/**/*.md'",
    "test": "npm run test:presets && npm run validate",
    "test:presets": "node scripts/test-presets.js",
    "check": "npm run lint && npm run test",
    "validate": "node scripts/validate-presets.js"
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "htmlhint": "^1.9.0",
    "markdownlint-cli2": "^0.21.0",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
